{
  "appId": "com.neuronodes.app",
  "appName": "NeuroNodes",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#FDFCF0",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  },
  "android": {
    "buildOptions": {
      "releaseType": "APK"
    }
  }
}
